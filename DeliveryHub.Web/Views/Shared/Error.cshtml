@model DeliveryHub.Web.Models.ErrorViewModel

@{
    ViewData["Title"] = "Ошибка";
}

<div class="text-center py-5">
    <h1 class="text-danger mb-3">Произошла ошибка</h1>

    <p class="lead">
        Не удалось обработать запрос. Попробуйте повторить действие позже.
    </p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted">
            Идентификатор запроса:
            <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Orders" asp-action="Index" class="btn btn-primary mt-3">
        Вернуться к списку заказов
    </a>
</div>